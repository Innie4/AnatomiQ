{
  "name": "anatomiq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/prepare-database.mjs && next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "node --test --import tsx tests/local-question-generator.test.ts",
    "test:regression": "node --test --import tsx tests/storage.regression.test.ts",
