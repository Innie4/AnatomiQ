generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model AnalyticsCounter {
  id           String        @id @default(uuid())
  key          String        @unique
  metric       CounterMetric
  topicId      String?
  questionType QuestionType?
  count        Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  topic     Topic?        @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model AuditLog {
  id            String      @id @default(uuid())
  facultyUserId String
  action        String
  resource      String
  resourceId    String?
  details       String?
  ipAddress     String?
  userAgent     String?
  createdAt   DateTime    @default(now())
  facultyUser FacultyUser @relation(fields: [facultyUserId], references: [id], onDelete: Cascade)

  @@index([action, createdAt])
  @@index([facultyUserId, createdAt])
  @@index([resource, resourceId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Concept {
  id                              String        @id @default(uuid())
  name                            String
  slug                            String
  scopeKey                        String        @unique
  description                     String?
  aliases                         String?
  topicId                         String
  subtopicId                      String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  subtopic    Topic?        @relation("Concept_subtopicIdToTopic", fields: [subtopicId], references: [id])
  topic       Topic         @relation("Concept_topicIdToTopic", fields: [topicId], references: [id])
  ConceptFact ConceptFact[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ConceptFact {
  id            String       @id @default(uuid())
  conceptId     String
  chunkId       String
  fact          String
  sourceSnippet String?
  createdAt DateTime     @default(now())
  chunk     ContentChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  concept   Concept      @relation(fields: [conceptId], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ContentChunk {
  id                                   String        @id @default(uuid())
  materialId                           String
  topicId                              String
  subtopicId                           String?
  sequence                             Int
  heading                              String?
  text                                 String
  conceptSummary                       String?
  tokenEstimate                        Int?
  sourceHash                           String
  embedding                            String?
  citations                            String?
  createdAt   DateTime      @default(now())
  ConceptFact ConceptFact[]
  material    Material      @relation(fields: [materialId], references: [id], onDelete: Cascade)
  subtopic    Topic?        @relation("ContentChunk_subtopicIdToTopic", fields: [subtopicId], references: [id])
  topic       Topic         @relation("ContentChunk_topicIdToTopic", fields: [topicId], references: [id])

  @@unique([materialId, sequence])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Course {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  department  String     @default("Human Anatomy")
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  Material    Material[]
  Question    Question[]
  Topic       Topic[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model FacultyUser {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  fullName     String
  department   String     @default("Human Anatomy")
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  AuditLog     AuditLog[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Material {
  id                               String         @id @default(uuid())
  title                            String
  fileName                         String
  fileType                         String
  mimeType                         String
  kind                             MaterialKind
  courseId                         String
  topicId                          String
  subtopicId                       String?
  storageKey                       String
  storageUrl                       String
  extractedText                    String?
  extractedHash                    String?
  status                           MaterialStatus @default(UPLOADED)
  processingNotes                  String?
  metadata                         String?
  sourcePages                      Int?
  createdAt                        DateTime       @default(now())
  updatedAt                        DateTime       @updatedAt
  ContentChunk ContentChunk[]
  course       Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  subtopic     Topic?         @relation("Material_subtopicIdToTopic", fields: [subtopicId], references: [id])
  topic        Topic          @relation("Material_topicIdToTopic", fields: [topicId], references: [id])
  Question     Question[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Question {
  id                               String                @id @default(uuid())
  courseId                         String
  topicId                          String
  subtopicId                       String?
  materialId                       String?
  type                             QuestionType
  stem                             String
  options                          String?
  answer                           String
  explanation                      String?
  difficulty                       Difficulty
  authoringMode                    QuestionAuthoringMode @default(GENERATED)
  sourceChunkIds                   String
  sourceSnippet                    String
  questionHash                     String                @unique
  textFingerprint                  String?
  embedding                        String?
  createdAt                        DateTime              @default(now())
  updatedAt                        DateTime              @updatedAt
  manualOrder Int?
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  material    Material? @relation(fields: [materialId], references: [id])
  subtopic    Topic?    @relation("Question_subtopicIdToTopic", fields: [subtopicId], references: [id])
  topic       Topic     @relation("Question_topicIdToTopic", fields: [topicId], references: [id])

  @@unique([materialId, manualOrder])
  @@index([materialId, manualOrder])
  @@index([materialId, type])
  @@index([subtopicId, type])
  @@index([topicId, type])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Topic {
  id                                          String             @id @default(uuid())
  name                                        String
  slug                                        String             @unique
  summary                                     String?
  level                                       Int                @default(0)
  isSystem                                    Boolean            @default(false)
  courseId                                    String
  parentTopicId                               String?
  createdAt                                   DateTime           @default(now())
  updatedAt                                   DateTime           @updatedAt
  AnalyticsCounter                            AnalyticsCounter[]
  conceptsAsSubtopic                          Concept[]          @relation("Concept_subtopicIdToTopic")
  conceptsAsTopic                             Concept[]          @relation("Concept_topicIdToTopic")
  chunksAsSubtopic                            ContentChunk[]     @relation("ContentChunk_subtopicIdToTopic")
  chunksAsTopic                               ContentChunk[]     @relation("ContentChunk_topicIdToTopic")
  materialsAsSubtopic                         Material[]         @relation("Material_subtopicIdToTopic")
  materials                                   Material[]         @relation("Material_topicIdToTopic")
  questionsAsSubtopic                         Question[]         @relation("Question_subtopicIdToTopic")
  questions                                   Question[]         @relation("Question_topicIdToTopic")
  course                                      Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  parentTopic                                 Topic?             @relation("TopicToTopic", fields: [parentTopicId], references: [id])
  childTopics                                 Topic[]            @relation("TopicToTopic")

  @@unique([courseId, name, parentTopicId])
}

enum CounterMetric {
  TOPIC_STUDY
  QUESTION_GENERATION
  EXAM_START
}

enum Difficulty {
  FOUNDATIONAL
  INTERMEDIATE
  ADVANCED
}

enum MaterialKind {
  PDF
  NOTE
  IMAGE
}

enum MaterialStatus {
  UPLOADED
  PROCESSING
  READY
  FAILED
}

enum QuestionAuthoringMode {
  GENERATED
  MANUAL
}

enum QuestionType {
  MCQ
  SHORT_ANSWER
  THEORY
}
